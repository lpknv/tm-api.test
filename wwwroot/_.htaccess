Options -Indexes

<IfModule mod_rewrite.c>
RewriteEngine On
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# Versteckte Dateien blockieren
<FilesMatch "^\.">
  Require all denied
</FilesMatch>

# Sensible Dateien blockieren
<FilesMatch "\.(env|ini|log|sql|bak|dist|old|zip|tar|gz)$">
  Require all denied
</FilesMatch>