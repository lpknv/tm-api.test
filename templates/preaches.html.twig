{% extends 'base.html.twig' %}

{% block body %}

<section class="testimonial-section-solar-classic">
  <div class="auto-container">
    <div class="row align-items-center">
      <div class="col-xl-12">
        <div class="sec-title">
          <div class="section-title">
            <h1 class="title">Predigten</h1>
          </div>
        </div>
      </div>
    </div>
    <div class="row" id="sermon-players"></div>
  </div>
</section>
{% endblock %}

{% block javascripts %}
<script src="/assets/js/oyoplayer.js"></script>
<script>
$(document).ready(function () {
  const tracks = [
    {name: "Andreas Seo", file: "/assets/Predigt15.03.2026.mp3"},
    {name: "Andreas Seo", file: "/assets/Predigt-2026-03-08.mp3"},
    {name: "Andreas Seo", file: "/assets/Predigt-2026-03-01.mp3"},
  ];

  function extractDate(filename) {
    let m = filename.match(/(\d{4})-(\d{2})-(\d{2})/);
    if (m) return { year: m[1], month: m[2], day: m[3] };

    m = filename.match(/(\d{2})\.(\d{2})\.(\d{4})/);
    if (m) return { year: m[3], month: m[2], day: m[1] };

    return null;
  }

  function formatDate(d) {
    return d.day + "." + d.month + "." + d.year;
  }

  tracks.forEach(function(track, i) {
    const filename = track.file.split("/").pop();
    const date = extractDate(filename);
    const playerId = "player-" + i;

    $("#sermon-players").append(`
      <div class="col-lg-6 col-12">
        <div class="single-testi-box sermon-player-box">
          <div class="testi-autor-box">
            <div class="testi-autor-content">
              <h5 class="autor-title">${track.name}</h5>
              <p class="autor-desi">${date ? formatDate(date) : filename}</p>
            </div>
          </div>
          <div class="testi-desc">
            <div id="${playerId}" class="player-host"></div>
          </div>
        </div>
      </div>
    `);

    const audioPlayer = new oyoPlayer();
    $("#" + playerId).append(audioPlayer);
    audioPlayer.addToPlaylist(track.file, filename);
    audioPlayer.setSourceIndex(1);
  });
});
</script>

{% endblock%}