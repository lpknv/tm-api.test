<div class="joint-event-section-charity">
  <div class="row">
    <div class="col-lg-12">
      {% for event in upcoming_events|sort %}
        <div class="joint-event-box">
          <div class="event-inner-box first">
            <div class="joint-event-date">
              <h1>{{ event.date_start.day }}</h1>
            </div>
            <div class="joint-event-month">
              <h5>{{ event.date_start.month }}</h5>
              <p>{{ event.date_start.year }}</p>
            </div>
          </div>
          <div class="event-inner-box">
            <div class="event-content">
              <div class="event-title">
                <h3>{{ event.name }}</h3>
                <h5>{{ event.date_start.full }} - {{ event.date_end.full }}</h5>
              </div>
            </div>
          </div>
          <div class="event-inner-box">
            <div class="event-location">
              <ul>
                <li><img src="/assets/images/charity/event-icon1.png" alt="icon">{{ event.location|raw }}</li>
              </ul>
            </div>
          </div>
          {% if show_link %}
            <div class="joint-event-btn">
              <a href="event-details.html">Mehr erfahren<i class="fa-solid fa-arrow-right-long"></i></a>
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>