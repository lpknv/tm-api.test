<!DOCTYPE html>
<html lang="de">

<head>
  <meta charset="UTF-8">
  <title>{% block title %}EFG Hückelhoven-Baal - Wir sind die evanglisch-freikirchliche Gemeinde in Hückelhoven-Baal{% endblock %}</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  {% block stylesheets %}
  {% endblock %}
  {% block javascripts %}
  {% endblock %}
  <link href="/assets/css/bootstrap.min.css" rel="stylesheet">
  <link href="/assets/css/style.css" rel="stylesheet">
  <link href="/assets/css/responsive.css" rel="stylesheet">
  <link href="/assets/css/main.css" rel="stylesheet">
</head>

<body>
  <div class="page-wrapper">
    <div class="preloader">
      <div class="loader"></div>
    </div>

    <header class="main-header header-solar-renewable">
      <div class="header-lower">
        <div class="auto-container">
          <div class="main-box">
            <div class="logo-box">
              <div class="logo"><a href="environment-classic.html"><img src="/images/logo-white.png" alt="" title="econet"></a></div>
            </div>
            <!--Nav Box-->
            <div class="nav-outer">
              <nav class="nav main-menu">
                <ul class="navigation">
                  <li class="current"><a href="#">Start</a></li>
                  <li class="dropdown"><a href="#">Über uns</a>
                    <ul>
                      <li><a href="">Gemeinde</a></li>
                      <li><a href="">Glaubensgemeinschaft</a></li>
                      <li><a href="">Finanzierung</a></li>
                      <li><a href="">Teams</a></li>
                    </ul>
                  </li>
                  <li><a href="">Gruppen</a></li>
                  <li class="dropdown"><a href="#">Veranstaltungen</a>
                    <ul>
                      <li><a href="">Baseballcamp</a></li>
                    </ul>
                  </li>
                  <li><a href="">Predigten</a></li>
                  <li><a href="">Kontakt</a></li>
                </ul>
              </nav>
              <!-- Mobile Nav toggler -->
              <div class="mobile-nav-toggler"><span class="icon lnr-icon-bars"></span></div>
            </div>
          </div>
        </div>
      </div>

      <div class="mobile-menu">
        <div class="menu-backdrop"></div>

        <nav class="menu-box">
          <div class="upper-box">
            <div class="nav-logo"><a href="index.html"><img src="/images/logo.png" alt=""></a></div>
            <div class="close-btn"><i class="icon fa fa-times"></i></div>
          </div>

          <ul class="navigation clearfix">
          </ul>
          <ul class="contact-list-one">
            <li>
              <div class="contact-info-box">
                <i class="icon lnr-icon-phone-handset"></i>
                <span class="title">Call Now</span>
                <a href="tel:+92880098670">+92 (8800) - 98670</a>
              </div>
            </li>
            <li>
              <div class="contact-info-box">
                <span class="icon lnr-icon-envelope1"></span>
                <span class="title">Send Email</span>
                <a href="mailto:help@company.com">help@company.com</a>
              </div>
            </li>
            <li>
              <div class="contact-info-box">
                <span class="icon lnr-icon-clock"></span>
                <span class="title">Send Email</span>
                Mon - Sat 8:00 - 6:30, Sunday - CLOSED
              </div>
            </li>
          </ul>
          <ul class="social-links">
            <li><a href="#"><i class="fa-brands fa-x-twitter"></i></a></li>
            <li><a href="#"><i class="fab fa-facebook-f"></i></a></li>
            <li><a href="#"><i class="fab fa-pinterest"></i></a></li>
            <li><a href="#"><i class="fab fa-instagram"></i></a></li>
          </ul>
        </nav>
      </div>

      <div class="sticky-header">
        <div class="auto-container">
          <div class="inner-container">
            <div class="logo">
              <a href="index.html"><img src="/images/logo-2.png" alt=""></a>
            </div>
            <div class="nav-outer">

              <nav class="main-menu">
                <div class="navbar-collapse show collapse clearfix">
                  <ul class="navigation clearfix">
                  </ul>
                </div>
              </nav>


              <div class="mobile-nav-toggler"><span class="icon lnr-icon-bars"></span></div>
            </div>
          </div>
        </div>
      </div>
    </header>

    {% block body %}{% endblock %}

    <footer class="main-footer-one">
      <div class="main-footer-section">
        <div class="auto-container">
          <div class="row g-4">
            <div class="col-xl-2 col-lg-12">
              <div class="footer-widget-content social">
                <div class="logo">
                  <a href="/">
                    <img width="300" src="/assets/images/logo-white.png" alt="logo">
                  </a>
                </div>
                <ul class="footer-social">
                  <li><a target="_blank" href="https://www.youtube.com/@EFG-Hueckelhoven"><i class="fa-brands fa-youtube"></i></a></li>
                  <li><a target="_blank" href="https://www.instagram.com/efg_baal/"><i class="fa-brands fa-instagram"></i></a></li>
                </ul>
              </div>
            </div>
            <div class="col-xl-2 col-lg-12">
              <div class="footer-widget-content">
                <h3 class="footer-title">Adresse</h3>
                <div class="footer-content">
                  <ul class="footer-menu">
                    <li>
                      <a href="https://maps.app.goo.gl/Vuu92JzpuGvfg1Sx6" target="_blank" class="location">Fringstraße 8a<br />41836 Hückelhoven (Baal)<i class="fa-solid fa-arrow-right-long"></i></a>
                    </li>
                  </ul>
                </div>
              </div>
            </div>
            <div class="col-xl-2 col-lg-12">
              <div class="footer-widget-content">
                <h3 class="footer-title">Kontakt</h3>
                <ul class="footer-menu">
                  {% for link, label in {
                    'mailto:info@efg-hueckelhoven.de': 'info(at)efg-hueckelhoven.de',
                    'tel:024352078': '02435 2078',
                  } %}
                  <li><a href="{{ link }}">{{ label }}<i class="fa-solid fa-arrow-right-long"></i></a></li>
                  {% endfor %}
                </ul>
              </div>
            </div>
            <div class="col-xl-2 col-lg-12">
              <div class="footer-widget-content">
                <h3 class="footer-title">Links</h3>
                <ul class="footer-menu">
                  {% for link, label in {
                    '/datenschutz': 'Datenschutz',
                    '/impressum': 'Impressum',
                    '/kontakt': 'Kontakt',
                  } %}
                  <li><a href="{{ link }}">{{ label }}<i class="fa-solid fa-arrow-right-long"></i></a></li>
                  {% endfor %}
                </ul>
              </div>
            </div>
            <div class="col-xl-3 col-lg-12">
              <div class="footer-widget-content">
                <h3 class="footer-title">Zugänge beantragen</h3>
                <ul class="footer-menu">
                  {% for link, label in {
                    '/formular-churchtools': 'Churchtools',
                    '/formular-netzwerkspeicher': 'Netzwerkspeicher',
                  } %}
                  <li><a href="{{ link }}">{{ label }}<i class="fa-solid fa-arrow-right-long"></i></a></li>
                  {% endfor %}
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </footer>
  </div>
  <div class="scroll-to-top scroll-to-target" data-target="html"><span class="fa fa-angle-up"></span></div>

  <script src="/assets/js/jquery.js"></script>
  <script src="/assets/js/popper.min.js"></script>
  <script src="/assets/js/bootstrap.min.js"></script>
  <script src="/assets/js/magnific.js"></script>
  <script src="/assets/js/wow.js"></script>
  <script src="/assets/js/appear.js"></script>
  <script src="/assets/js/swiper.min.js"></script>
  <script src="/assets/js/jquery.counterup.min.js"></script>
  <script src="/assets/js/waypoints.min.js"></script>
  <script src="/assets/js/nice-select.js"></script>
  <script src="/assets/js/gsap.min.js"></script>
  <script src="/assets/js/ScrollTrigger.min.js"></script>
  <script src="/assets/js/SplitText.js"></script>
  <script src="/assets/js/cusor-text.js"></script>
  <script src="/assets/js/script.js"></script>
</body>

</html>